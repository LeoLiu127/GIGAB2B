# GIGA B2B 多市场凭证配置（模板文件）
#
# 使用方法：
#   1. 复制本文件为 .env
#   2. 在 .env 中填入真实凭证
#   3. giga_config.py 会自动从 .env 读取
#
# 警告：.env 文件含敏感信息，切勿提交到版本控制！
#       已被 .gitignore 忽略。

# ── 美国 ──────────────────────────────────────
GIGA_US_CLIENT_ID=
GIGA_US_CLIENT_SECRET=

# ── 德国(含税) ────────────────────────────────
GIGA_DE_TAX_CLIENT_ID=
GIGA_DE_TAX_CLIENT_SECRET=

# ── 德国(免税) ────────────────────────────────
GIGA_DE_TAXFREE_CLIENT_ID=
GIGA_DE_TAXFREE_CLIENT_SECRET=

# ── 英国 ──────────────────────────────────────
GIGA_UK_CLIENT_ID=
GIGA_UK_CLIENT_SECRET=

# ── 法国 ──────────────────────────────────────
GIGA_FR_CLIENT_ID=
GIGA_FR_CLIENT_SECRET=

# ── 通用 ──────────────────────────────────────
# sandbox | production（默认 production）
GIGA_ENV=production

# Web 访问保护（开发阶段默认关闭；恢复登录时设为 1，并设置至少 20 位随机密码）
GIGAB2B_AUTH_ENABLED=0
GIGAB2B_ACCESS_PASSWORD=
# 后端默认只监听本机；通过前端代理或 Nginx 访问。确需直连时才改为 0.0.0.0
GIGAB2B_HOST=127.0.0.1
# HTTPS 反向代理部署时设为 1；本机 HTTP 开发保持 0
GIGAB2B_COOKIE_SECURE=0

# ── image-studio AI 凭证 ────────────────────────
# MiniMax：AI 文案生成（标题/五点/描述/Search Terms）
# 模型选择说明:
#   - MiniMax-Text-01  (推荐) 非 reasoning 模型,直接输出 JSON,适合 Listing 生成
#   - MiniMax-M3       reasoning 模型,会输出大量 <think>...思考过程,
#                       容易被 max_tokens 截断,导致内容为空,不推荐
MINIMAX_API_KEY=
MINIMAX_API_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-Text-01

# laozhang：AI 图片生成（主图/副图/A+图）
LAOZHANG_API_KEY=
LAOZHANG_API_URL=https://api.laozhang.ai/v1
LAOZHANG_IMAGE_MODEL=gemini-3.1-flash-image-preview
